<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%date{ISO8601} priority=%-5level source=%logger %mdc %message%n %ex{2}</pattern>
        </encoder>
    </appender>

    <root level="${root.log.level:-ERROR}">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>